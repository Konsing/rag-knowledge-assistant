# LLM Generation — set provider to "openai" or "claude"
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=research_papers

# Chunking Parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval Parameters
TOP_K=5
SCORE_THRESHOLD=0.1

# MCP Server
MCP_PORT=8811
